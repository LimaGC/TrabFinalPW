{
  "name": "backend-api",
  "version": "1.0.0",
  "description": "Backend API for Class",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "knex:migrate:test": "cross-env NODE_ENV=test && knex migrate:latest --env test",
    "knex:seed:test": "knex seed:run --env test",
    "knex:test": "npm run knex:migrate:test && npm run knex:seed:test && node src/server.js",
    "knex:migrate:staging": "cross-env NODE_ENV=staging && knex migrate:latest --env staging",
    "knex:seed:staging": "cross-env NODE_ENV=staging && knex seed:run --env staging",
    "knex:staging": "cross-env NODE_ENV=staging && npm run knex:migrate:staging && npm run knex:seed:staging && node src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "Guilherme Lima",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "body-parser": "^2.2.2",
    "consign": "^0.1.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "jwt-simple": "^0.5.6",
    "knex": "^3.2.9",
    "moment": "^2.30.1",
    "node-fetch": "^3.3.2",
    "passport": "0.5.2",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "sqlite3": "^6.0.1",
    "uuid": "8.3.2",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0"
  }
}
